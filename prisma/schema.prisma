// prisma/schema.prisma
generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = []
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Url {
  id          String  @id @default(uuid())
  originalUrl String
  shortCode   String? @unique
  count       String? @default("0")
}
